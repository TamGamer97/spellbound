#
# Local development environment variables.
# Copy to `.env` (or `.env.local`) and fill in your values.
#
# IMPORTANT: Do not commit `.env` / `.env.local` — they are gitignored.
#

# Supabase (frontend auth / database client)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: override dictionary/profanity endpoints used by the client fallback
SPELLBOUND_DICTIONARY_API=https://api.dictionaryapi.dev/api/v2/entries/en
SPELLBOUND_PROFANITY_API=https://www.purgomalum.com/service/containsprofanity

# Optional: if you host a word blocklist file yourself
SPELLBOUND_BLOCKLIST_URL=

