# Netlify redirects & rewrites (publish root)
# Order: more specific paths first. Query strings are preserved on rewrites.
/    /spellbound-redesigned.html    200

# Live game stays on the original game page
/game    /game.html    200

# App shell (redesign): home + embedded lobby
/lobby   /spellbound-redesigned.html    200
/        /spellbound-redesigned.html    200

# Legacy → canonical (avoid old index / lobby HTML as entry points)
/index.html                  /         301
/lobby.html                  /lobby    301
/spellbound-redesigned.html  /         301
