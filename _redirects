# Netlify redirects & rewrites (publish root)
# 200! = force rewrite even if index.html or another file would match (shadowing)

# Root URL: always the redesign (not legacy index.html)
/    /spellbound-redesigned.html    200!

# Live game
/game    /game.html    200

# Lobby screen (same app shell)
/lobby   /spellbound-redesigned.html    200!

# Legacy → canonical
/index.html                  /         301
/lobby.html                  /lobby    301
/spellbound-redesigned.html  /         301
